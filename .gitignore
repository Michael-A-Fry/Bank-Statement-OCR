# R
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Runtime I/O (never commit real statements or generated conversions/logs).
# The folder poller drops originals into inbox/ and moves them to processed/ or
# failed/; conversions land in out/ and outbox/. All of these can hold REAL bank
# statements on a deployed box, so none may ever be committed.
/out/
/outputs/
/outbox/
/inbox/
/processed/
/failed/
/stuck/
/uploads/
/requests/
/audit-drafts/
*.audit.md
bulk-audit.md
/logs/
*.log
# run/feedback logs the test suite generates
tests/testthat/logs/

# Scratch / temp
scratch/
tmp/
*.tmp

# Offline package produced by make-bundle.bat / scripts/bundle-offline.R (the whole
# app + large package/installer binaries; built on an internet PC, copied to the
# server -- never committed).
/StatementStudio-offline/
/bso-offline/
/bso-offline-repo/

# NOTE: samples/ is intentionally tracked — it is the public specimen corpus
# used for template design and golden-file tests.

# Real / personal statement data staged for LOCAL testing only.
# NEVER committed. Drop your files in samples/_private_staging/ -- everything
# there is ignored except its README, which documents the folder.
samples/_private_staging/*
!samples/_private_staging/README.md

# Belt-and-braces: never commit real statements dropped anywhere private,
# whatever the extension.
/private/
/incoming/
**/*.private.*

# X-ray screenshots may render real statements -- never commit
screenshots/

# stray R plotting-device output
Rplots.pdf

# Playwright tooling used only for local UI screenshots (not part of the app)
node_modules/
package.json
package-lock.json

# Deployment config (holds the admin password) - keep the .example committed, not this.
/config/config.yaml

# Qlik feed folder (holds REAL statements) - never commit.
/feed/
